// BlogTalk v2.0 — Prisma schema
// Supabase PostgreSQL via Session pooler (DATABASE_URL) + Direct (DIRECT_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js models ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" | "admin"

  accounts  Account[]
  sessions  Session[]
  comments  Comment[]
  likes     Like[]
  bookmarks Bookmark[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models (Sprint 2-3 ready) ────────────────────────

model Comment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  slug      String   // post slug
  authorId  String
  parentId  String?  // threaded replies

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("Replies")

  @@index([slug])
}

model Like {
  id     String @id @default(cuid())
  slug   String
  userId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([slug, userId])
}

model Bookmark {
  id     String @id @default(cuid())
  slug   String
  userId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([slug, userId])
}

// ─── Sprint 6 models ──────────────────────────────────────

model PostView {
  id   String @id @default(cuid())
  slug String
  
  createdAt DateTime @default(now())

  @@index([slug])
}

model Subscriber {
  id    String @id @default(cuid())
  email String @unique

  createdAt DateTime @default(now())
}
