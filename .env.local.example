# ─── Auth.js v5 ─────────────────────────────────────────
AUTH_SECRET=           # openssl rand -base64 32
AUTH_GOOGLE_ID=        # Google OAuth client ID
AUTH_GOOGLE_SECRET=    # Google OAuth client secret
AUTH_URL=http://localhost:3000  # Required for local dev (Vercel auto-detects)

# ─── Supabase PostgreSQL ────────────────────────────────
DATABASE_URL=          # Session pooler connection string (port 6543)
DIRECT_URL=            # Direct connection string (port 5432)

# ─── Analytics Drain ────────────────────────────────────
ANALYTICS_DRAIN_SECRET=  # Signing secret from Vercel Drain config
